{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:default",
    "fs:allow-read",
    {
      "identifier": "fs:allow-write",
      "allow": [{ "path": "**" }]
    },
    "opener:default",
    "opener:allow-open-path"
  ]
}