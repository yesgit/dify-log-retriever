{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dify Log Retriever",
  "version": "0.1.0",
  "identifier": "com.local.dify-log-retriever",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Dify Log Retriever",
        "width": 1280,
        "height": 820,
        "minWidth": 1040,
        "minHeight": 680
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "dmg", "msi", "nsis"],
    "icon": ["icons/icon.png"]
  }
}
